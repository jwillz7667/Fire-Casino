# dependencies
node_modules/
.pnpm-store/

# env — never commit real secrets; only .env.example is tracked
.env
.env.*
!.env.example

# build output
dist/
build/
out/
.next/
.turbo/
*.tsbuildinfo

# next.js generated ambient types (regenerated by next build/dev)
next-env.d.ts

# prisma
packages/db/src/generated/

# test / coverage
coverage/
.vitest/

# logs
*.log
npm-debug.log*
pnpm-debug.log*

# os / editor
.DS_Store
Thumbs.db
.idea/
.vscode/*
!.vscode/extensions.json
*.pem
.vercel
.env*.local

# Dragon's Hoard Godot build is served from Cloudflare R2, not committed.
apps/arcade/public/dragon-hoard/
# Royal Ascendant Godot build is served from Cloudflare R2, not committed.
apps/arcade/public/royal-ascendant/

# Raw ElevenLabs mp3 intermediate for the lobby loop (regenerable; the .mp3 is committed).
apps/arcade/public/audio/raw/

# Legend of the Flaming Kirin 4K raw Nano Banana art (~345MB) — too large for git and
# regenerable from games/flaming-kirin/tools/gen-assets.py; only the processed art/ ships.
assets/flaming-kirin-assets/
