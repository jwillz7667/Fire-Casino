# ============================================================
# Fire Casino (Aureus) — environment template
# Copy to .env for local dev. Validated by packages/shared/src/env.ts at boot.
# Never commit a real .env. Only this example is tracked.
# ============================================================

# --- core ---
NODE_ENV=development
PLATFORM_MODE=OPERATOR          # OPERATOR | COMPLIANCE
DATABASE_URL=postgresql://aureus:aureus@localhost:5432/aureus
REDIS_URL=redis://localhost:6379

# --- auth ---
JWT_ACCESS_SECRET=change-me-access-secret-min-32-chars-long
JWT_REFRESH_SECRET=change-me-refresh-secret-min-32-chars-long
JWT_ACCESS_TTL=900              # seconds (15m)
JWT_REFRESH_TTL=2592000         # seconds (30d)
JWT_KID=key-1
COOKIE_DOMAIN=localhost
COOKIE_SECURE=false             # true in production (https)
ARGON2_MEMORY_KIB=19456

# --- urls / cors ---
API_URL=http://localhost:4000
API_PORT=4000
CONSOLE_URL=http://localhost:3000
ARCADE_URL=http://localhost:3001
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:3001

# --- money ---
CREDIT_MINOR_UNITS=1000         # 1 credit = 1000 minor units (3 dp)
DEFAULT_GAME_RTP_BPS=9400       # 94.00%

# --- storage (Cloudflare R2; stub client in dev) ---
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_ASSETS=aureus-assets
R2_BUCKET_KYC=aureus-kyc

# --- compliance (stub providers in dev) ---
KYC_PROVIDER=stub               # stub | <real provider>
GEO_PROVIDER=stub
AML_ENABLED=true
SELF_EXCLUSION_ENABLED=true
REDEMPTION_KYC_THRESHOLD_MINOR=50000   # require KYC at/above this redeem amount

# --- realtime / workers ---
SOCKET_ADAPTER=redis
OUTBOX_RELAY_INTERVAL_MS=1000

# --- frontends (Next.js public) ---
NEXT_PUBLIC_API_URL=http://localhost:4000
