# Godot editor/import cache — regenerated by `godot --import`, never commit.
.godot/

# Local export output (built by web/build.sh, staged into apps/arcade/public).
build/

# Raw art lives in the repo-root Dragon-icons/ and is processed into art/ by
# tools/prep-assets.sh. art/*.import IS committed so CI/headless builds need no re-import.

# ElevenLabs raw mp3 intermediates (if ever added).
audio/raw/
