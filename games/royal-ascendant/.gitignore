# Godot editor/import cache — regenerated by `godot --import`, never commit.
.godot/

# Local export output (built by web/build.sh, uploaded to R2).
build/

# Raw, un-prepped art is generated into art/ by tools/prep-assets.sh.
# (art/*.import IS committed so CI/headless builds need no re-import.)

# ElevenLabs raw mp3 intermediates (regenerated by audio/generate_sfx.py).
# Converted audio/out/*.{ogg,wav} ARE committed.
audio/raw/
