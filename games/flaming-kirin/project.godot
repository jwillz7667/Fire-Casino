; Legend of the Flaming Kirin — portrait web slot client (server-authoritative; renders only
; the outcome delivered by the host page over the JS bridge). GL Compatibility so it runs on
; WebGL2 in every browser. Self-contained: all art + audio ship in this repo (art/, audio/).
; The ornate GOLD reel frame (art/ui/reel_frame.png, transparent centre) is drawn ON TOP of a
; dark backplate (art/ui/reel_backplate.jpg) with the per-reel clipped symbol windows in
; between, so symbols read as emerging from behind the top of the frame.

config_version=5

[application]

config/name="Legend of the Flaming Kirin"
config/version="1.0.0"
run/main_scene="res://slot/main.tscn"
config/features=PackedStringArray("4.6", "GL Compatibility")
config/icon="res://art/symbols/sym_wild.png"
boot_splash/show_image=false

[display]

window/size/viewport_width=1080
window/size/viewport_height=1920
window/stretch/mode="canvas_items"
window/stretch/aspect="expand"
window/handheld/orientation=1

[debug]

gdscript/warnings/enable=false
gdscript/warnings/treat_warnings_as_errors=false

[rendering]

renderer/rendering_method="gl_compatibility"
renderer/rendering_method.mobile="gl_compatibility"
textures/canvas_textures/default_texture_filter=1
environment/defaults/default_clear_color=Color(0.012, 0.03, 0.06, 1)
